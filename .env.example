# Slack — see CLAUDE.md for required scopes and event subscriptions
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_TPM_LIMIT=80000
ANTHROPIC_RPM_LIMIT=1000

# Database
DATABASE_URL=postgresql://user:password@host:5432/tinyhands?sslmode=require

# GitHub (optional — for auto-deploy and GitHub KB sources)
GITHUB_TOKEN=ghp_your-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=production

# Observability
LOG_LEVEL=info
DAILY_DIGEST_TIME=09:00
DAILY_BUDGET_USD=50

# Docker
DOCKER_BASE_IMAGE=tinyhands-runner:latest
DEFAULT_CONTAINER_CPU=1
DEFAULT_CONTAINER_MEMORY=2147483648
DEFAULT_JOB_TIMEOUT_MS=3600000
MAX_CONCURRENT_WORKERS=3

# Encryption (required for personal tool connections)
# Must be at least 32 characters — generate with: openssl rand -base64 32
# ENCRYPTION_KEY=your-32-character-encryption-key

# OAuth — Personal Tool Connections (all optional)
#
# Google OAuth credentials are bootstrap-only. Workspace admins bring their
# own Google Cloud OAuth client via the dashboard (Settings → Integrations →
# Google connection app). These env vars are only consulted on first boot of
# a single-tenant install, to seed workspace 1's credentials once. Runtime
# never reads them. Leave commented out for multi-tenant deployments — each
# workspace admin configures their own via the dashboard.
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# NOTION_OAUTH_CLIENT_ID=your-notion-client-id
# NOTION_OAUTH_CLIENT_SECRET=your-notion-client-secret
# GITHUB_OAUTH_CLIENT_ID=your-github-client-id
# GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret
# OAUTH_REDIRECT_BASE_URL=https://your-domain.com
