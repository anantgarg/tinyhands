{
  "name": "tinyhands",
  "version": "1.51.0",
  "description": "Extra hands for your Slack workspace — open-source, self-hosted AI agents powered by Claude",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "start": "node dist/index.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepare": "husky || true",
    "migrate": "npx tsx src/db/migrate.ts"
  },
  "keywords": [
    "slack",
    "slack-bot",
    "ai-agents",
    "claude",
    "anthropic",
    "llm",
    "automation",
    "ai-assistant",
    "chatbot",
    "customer-support",
    "knowledge-base",
    "bullmq",
    "docker"
  ],
  "author": "Anant Garg",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "bullmq": "^5.34.0",
    "connect-redis": "^7.1.1",
    "cron-parser": "^5.5.0",
    "dockerode": "^4.0.4",
    "dotenv": "^17.3.1",
    "epub2": "^3.0.2",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "ioredis": "^5.4.2",
    "mailparser": "^3.9.8",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "officeparser": "^6.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "unzipper": "^0.12.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dockerode": "^3.3.34",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.18.0",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "testcontainers": "^10.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.0"
  }
}
